# Git
.git
.gitignore

# Python caches
__pycache__
*.pyc
*.pyo
*.egg-info
.eggs

# Virtual environments
.venv
venv
env

# Environment and secrets
.env
.env.*
*.key
*.pem

# Data directories (mounted as volumes, not baked into image)
data/

# Tests
tests/

# Documentation (but keep schema SQL needed by init_db at runtime)
docs/*
!docs/architecture/
docs/architecture/*
!docs/architecture/client-db-schema.sql
!docs/architecture/console-db-schema.sql
*.md
!requirements.txt

# IDE and editor files
.vscode
.idea
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Claude artifacts — but keep agents (approval tokens needed by worker)
.claude/*
!.claude/agents/

# Infrastructure (not needed inside images)
infra/
