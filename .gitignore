# Pipeline output data — committed for now so it syncs between laptop and Pi5
# data/output/*.csv
# data/output/briefs/*.json

# Per-domain Layer 1 scan results — real third-party SMB data, never committed.
# The directory is regenerated on every pipeline run.
data/results/

# Benchmark results (local only)
data/benchmarks/*.json

# Pipeline input data — committed so it deploys with the repo
# data/input/CVR-extract.xlsx

# SQLite journal files (WAL mode)
*.db-shm
*.db-wal

# SQLite databases (runtime-generated, contain client data)
data/**/*.db
# Exception: enriched CVR database is a deployment artifact, synced via git
!data/enriched/companies.db

# Mac dev fixture — regenerated locally via `make dev-fixture-bootstrap`.
# Contains only filtered copies of committed prod data; never a source of truth.
data/dev/

# Secrets and credentials
*.key
*.pem
*.env.*
# Exceptions: example / template env files are committed
!infra/compose/.env.template
!infra/compose/.env.example
!infra/compose/.env.dev.example
secrets/
infra/compose/secrets/
infra/compose/secrets.dev/

# Valdí compliance logs (regenerated on each run)
.claude/agents/valdi/compliance/

# Git worktrees (Claude Code)
.claude/worktrees/

# Frontend build output + deps
src/api/frontend/node_modules/
src/api/static/dist/

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.eggs/

# Telethon session (credentials)
*.session

# Environment
.env
.venv/
venv/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Other-vendor AI tool configs (Heimdall's agent contracts live in .claude/agents/ + CLAUDE.md)
.cursorrules
.windsurfrules
skills-lock.json

# Test coverage artifact
.coverage

# OS
.DS_Store
Thumbs.db
