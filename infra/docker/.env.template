# Heimdall Pi5 Docker Stack — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.

# --- API Keys ---
CLAUDE_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_OPERATOR_CHAT_ID=
GRAYHATWARFARE_API_KEY=

# SSLMate CertSpotter — Sentinel-tier CT monitoring (daily per-client polling)
# Free tier: 10 full-domain queries/hour, sufficient for <240 Sentinel clients
# Sign up at https://sslmate.com/account/ct_search_api
CERTSPOTTER_API_KEY=

# Serper.dev — Google search for domain discovery in CVR enrichment tool (local only, not used on Pi5)
# Sign up at https://serper.dev/ — 2,500 free queries
SERPER_API_KEY=

# --- Infrastructure ---
TAILSCALE_AUTH_KEY=

# --- Operator Console (HTTP Basic Auth on /console/* and /app) ---
# Both must be set for auth middleware to activate. If either is empty,
# the console is served without authentication (local dev only).
CONSOLE_USER=admin
CONSOLE_PASSWORD=

# --- Backups ---
# Destination directory for scripts/backup.sh. On Pi5 this is the
# microSD mount (/mnt/sdbackup/heimdall). Leave empty for default.
HEIMDALL_BACKUP_DIR=

# --- Worker Configuration ---
# Number of worker replicas (default: 3, max recommended for Pi5: 3)
# Adjust in docker-compose.yml deploy.replicas, not here
# WORKER_SCAN_TIMEOUT=300          # Max seconds per domain scan
# WORKER_CACHE_CHECK=true          # Check Redis cache before scanning

# --- Redis ---
# REDIS_URL=redis://redis:6379/0  # Set in docker-compose.yml, not here

# --- Monitoring ---
# HEALTH_CHECK_ENDPOINT=           # External uptime monitor URL (optional)
