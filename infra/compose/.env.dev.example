# Heimdall Mac Dev Stack — Environment Variables
#
# Copy to .env.dev and fill in values. Never commit .env.dev to git.
#
#   cp infra/compose/.env.dev.example infra/compose/.env.dev
#   $EDITOR infra/compose/.env.dev
#
# See docs/development.md for the BotFather walkthrough and what each
# key is for. Every `make dev-*` target refuses to run if .env.dev is
# missing.

# --- Dev Telegram bot (MUST be separate from prod) ---
# Create via @BotFather → /newbot → record the token.
# Then send a message to the new bot from your own Telegram and fetch
# the chat ID from https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_OPERATOR_CHAT_ID=
TELEGRAM_BOT_USERNAME=HeimdallSecurityDEVbot
# Comma-separated list of allowed CORS origins for POST /signup/validate.
# Prod: https://signup.digitalvagt.dk — set via Hetzner/Coolify env var.
# Dev default (used when blank): http://localhost:5173,http://127.0.0.1:5173
SIGNUP_ALLOWED_ORIGINS=

# --- Claude API ---
# For the dev loop you can reuse the prod key; move to a separate
# billing line when dev usage becomes material.
CLAUDE_API_KEY=

# --- SSLMate CertSpotter (CT monitoring) ---
# Reuse the prod key — free tier has plenty of headroom for dev polling.
CERTSPOTTER_API_KEY=

# --- GrayHat Warfare (S3 leak discovery) ---
# Reuse the prod key.
GRAYHATWARFARE_API_KEY=

# --- Serper.dev (CVR enrichment fallback search) ---
# Reuse the prod key.
SERPER_API_KEY=

# --- Operator Console (HTTP Basic Auth on /console/* and /app) ---
# Dev-only credentials. Both must be set.
CONSOLE_USER=admin
CONSOLE_PASSWORD=devpassword

# --- Infrastructure (not used locally, kept for parity with prod) ---
TAILSCALE_AUTH_KEY=
HEIMDALL_BACKUP_DIR=

# --- Dev/prod data isolation (M37 finalisation, 2026-04-26) ---
#
# Override the four host bind-mounts so DEV reads its own fixture data
# under data/dev/, never touching prod data/output/briefs, data/enriched,
# data/input, or data/results. Refresh the fixture via
# `make dev-fixture-bootstrap` (auto-runs as part of `make dev-up`).
#
# PROD must NOT set these — defaults in docker-compose.yml take over.
INPUT_HOST_DIR=../../data/dev/input
ENRICHED_HOST_DIR=../../data/dev/enriched
RESULTS_HOST_DIR=../../data/dev/results
BRIEFS_HOST_DIR=../../data/dev/briefs
