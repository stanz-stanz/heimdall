# =============================================================================
# Heimdall Worker — Multi-stage Dockerfile
# Target: linux/arm64 (Raspberry Pi 5)
# Resource budget: 1 GB RAM, 1 CPU core per replica
# =============================================================================

# ---------------------------------------------------------------------------
# Stage 1: Build Go CLI tools
# Builder runs natively on $BUILDPLATFORM, cross-compiles to $TARGETPLATFORM
# (avoids QEMU emulation of the Go compiler). cgo off — alpine has no cross
# C toolchain and all 5 tools are pure-Go.
# ---------------------------------------------------------------------------
FROM --platform=$BUILDPLATFORM golang:1.25-alpine AS go-builder

# Auto-supplied by buildx; declared so they're visible inside RUN.
ARG TARGETOS
ARG TARGETARCH

RUN apk add --no-cache git ca-certificates

# Keep the builder toolchain explicit. If a pinned dependency starts
# requiring a newer Go release, fail here and update the base image
# deliberately instead of downloading a different toolchain at build time.
ENV GOTOOLCHAIN=local
ENV CGO_ENABLED=0

# Install Go CLI tools one at a time (easier to debug failures).
# GOBIN is intentionally unset: `go install` refuses GOBIN when GOARCH
# differs from the host, so cross-compiled binaries land at
# /go/bin/${TARGETOS}_${TARGETARCH}/ and same-platform builds at /go/bin/.
# A single mv sweep below normalises both modes into /go/tools/.
RUN mkdir -p /go/tools
# Pinned versions — update deliberately, not silently via @latest
RUN GOOS=$TARGETOS GOARCH=$TARGETARCH go install github.com/projectdiscovery/httpx/cmd/httpx@v1.9.0
RUN GOOS=$TARGETOS GOARCH=$TARGETARCH go install github.com/rverton/webanalyze/cmd/webanalyze@v0.4.1
RUN GOOS=$TARGETOS GOARCH=$TARGETARCH go install github.com/projectdiscovery/subfinder/v2/cmd/subfinder@v2.13.0
RUN GOOS=$TARGETOS GOARCH=$TARGETARCH go install github.com/projectdiscovery/dnsx/cmd/dnsx@v1.2.3
RUN GOOS=$TARGETOS GOARCH=$TARGETARCH go install github.com/projectdiscovery/nuclei/v3/cmd/nuclei@v3.7.1

# Normalise output dir across cross-compile / native-compile modes.
RUN if [ -d "/go/bin/${TARGETOS}_${TARGETARCH}" ]; then \
        mv /go/bin/${TARGETOS}_${TARGETARCH}/* /go/tools/; \
    else \
        mv /go/bin/* /go/tools/; \
    fi

# ---------------------------------------------------------------------------
# Stage 2: Runtime image
# ---------------------------------------------------------------------------
FROM python:3.11-slim AS runtime

LABEL maintainer="Heimdall <heimdall@fsaf.dev>"
LABEL description="Heimdall scan worker — executes Layer 1 scan jobs from Redis queue"

# System deps needed by Go binaries and Python packages
RUN apt-get update \
 && apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        nmap \
 && rm -rf /var/lib/apt/lists/*

# Copy Go binaries from builder stage to /opt/go-tools/ (not /usr/local/bin/)
# to avoid pip overwriting them (Python httpx package installs a CLI wrapper
# at /usr/local/bin/httpx that shadows the Go binary)
COPY --from=go-builder /go/tools/httpx       /opt/go-tools/httpx
COPY --from=go-builder /go/tools/webanalyze  /opt/go-tools/webanalyze
COPY --from=go-builder /go/tools/subfinder   /opt/go-tools/subfinder
COPY --from=go-builder /go/tools/dnsx        /opt/go-tools/dnsx
COPY --from=go-builder /go/tools/nuclei      /opt/go-tools/nuclei
ENV PATH="/opt/go-tools:${PATH}"

# Bake nuclei templates at build time (no runtime internet needed)
# HOME set so nuclei config lands in a user-accessible location
ENV HOME=/home/heimdall
RUN mkdir -p /opt/nuclei-templates /home/heimdall \
 && /opt/go-tools/nuclei -update-templates -ud /opt/nuclei-templates \
 && test -n "$(find /opt/nuclei-templates -name '*.yaml' | head -1)"

# CMSeek — pure Python, git clone (no pip package available)
RUN apt-get update \
 && apt-get install -y --no-install-recommends git \
 && git clone https://github.com/Tuhinshubhra/CMSeeK.git /opt/cmseek \
 && cd /opt/cmseek && git checkout 20f9780d2e682874be959cfd487045c92e3c73f4 \
 && apt-get purge -y --auto-remove git \
 && rm -rf /var/lib/apt/lists/* /opt/cmseek/.git

# Create non-root user
RUN groupadd --gid 1000 heimdall \
 && useradd --uid 1000 --gid 1000 --create-home heimdall

# Create data directories the volumes will mount into
RUN mkdir -p /data/valdi /data/results /data/cache /config \
 && chown -R heimdall:heimdall /data /config /opt/nuclei-templates /opt/cmseek /home/heimdall

WORKDIR /app

# Install Python deps first (layer caching)
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy application code, agent data, scripts, and schema
COPY src/ ./src/
COPY config/ ./config/
COPY tools/ ./tools/
COPY .claude/agents/ ./.claude/agents/
COPY scripts/ ./scripts/
COPY docs/architecture/client-db-schema.sql ./docs/architecture/client-db-schema.sql

# Own everything by non-root user
RUN chown -R heimdall:heimdall /app

USER heimdall

# No HEALTHCHECK here — docker-compose.yml defines the authoritative one
# (file-mtime check against /tmp/healthcheck touched by the BRPOP loop).
# Keeping the Dockerfile check removed avoids drift with the compose check.

ENTRYPOINT ["python", "-m", "src.worker.main"]
