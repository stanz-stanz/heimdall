# Heimdall — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.

# Claude API — used by Finding Interpreter (Sprint 3.3)
CLAUDE_API_KEY=

# Telegram Bot — used for client message delivery (Sprint 4.1)
TELEGRAM_BOT_TOKEN=

# GrayHatWarfare — exposed cloud storage index (optional, free tier limited)
GRAYHATWARFARE_API_KEY=

# Worker scan layer — 0 = Layer 1 only, 1 = Layer 1 + Layer 2 (default: 0)
WORKER_MAX_LEVEL=0

# Enrichment workers — number of parallel subfinder batches (default: 3)
ENRICHMENT_WORKERS=3
