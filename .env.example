# Heimdall — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.

# Claude API — used by Finding Interpreter (Sprint 3.3)
CLAUDE_API_KEY=

# Telegram Bot — used for client message delivery (Sprint 4.1)
TELEGRAM_BOT_TOKEN=

# GrayHatWarfare — exposed cloud storage index (optional, free tier limited)
GRAYHATWARFARE_API_KEY=

# Worker scan layer — 0 = Layer 1 only, 1 = Layer 1 + Layer 2 (default: 0)
WORKER_MAX_LEVEL=0

# Enrichment workers — number of parallel subfinder batches (default: 3)
ENRICHMENT_WORKERS=3

# Telegram Operator Chat ID — used for delivery approval flow
TELEGRAM_OPERATOR_CHAT_ID=

# Serper API — used for search-based domain discovery in enrichment
SERPER_API_KEY=

# Operator Console — HTTP Basic Auth (required for /console/* and /app)
CONSOLE_USER=admin
CONSOLE_PASSWORD=

# Operator Console — session ticket TTLs (Stage A spec §4.3).
# Both have tolerant defaults; absence is operationally harmless.
# CONSOLE_SESSION_IDLE_TTL_MIN: sliding-window idle timeout (default: 15)
# CONSOLE_SESSION_ABSOLUTE_TTL_MIN: hard cap from issue (default: 720 = 12h)
CONSOLE_SESSION_IDLE_TTL_MIN=15
CONSOLE_SESSION_ABSOLUTE_TTL_MIN=720

# Operator Console — Secure cookie flag (Stage A spec §4.1).
# 1 = production posture (HTTPS terminating at the proxy).
# 0 = dev only (plain HTTP localhost, e.g. make dev-up).
HEIMDALL_COOKIE_SECURE=1

# Operator Console — login rate-limit overrides (Stage A spec §3.1.a).
# Production leaves both UNSET; defaults match the spec (5 fails, 15-min
# window). Override only for dev / manual-QA walkthroughs to dial down
# the lockout window. Invalid (non-int / sub-1) values silently fall
# back to the spec default.
# HEIMDALL_AUTH_RATE_LIMIT_THRESHOLD=5
# HEIMDALL_AUTH_RATE_LIMIT_WINDOW_SEC=900
